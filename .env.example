# Discord bot token — get from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# (Optional) Only respond in specific channel(s), comma-separated IDs
# CHANNEL_IDS=123456789012345678

# (Optional) Only respond to messages from specific webhook user(s) / bot name(s)
# TOURPLAY_WEBHOOK_NAME=Tourplay

# (Optional) Comma-separated Discord user IDs allowed to talk directly to the bot via @mention
# ALLOWED_USER_IDS=123456789012345678,987654321098765432
